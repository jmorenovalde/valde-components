{
  "name": "valde-components",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "jest --config ./jest.app.config.js",
    "test:dev": "jest --config ./jest.app.config.js --watch-all --coverage",
    "test:my-lib": "jest --config ./jest.my-lib.config.js",
    "test:my-lib:dev": "jest --config ./jest.my-lib.config.js --watch-all --coverage",
    "test:generate-output": "jest --json --outputFile=.jest-test-results.json",
    "docs:json": "compodoc -p ./tsconfig.json -e json -d .",
    "prebuild:storybook": "npm run test:generate-output",
    "storybook": "ng run valde-components:storybook",
    "storybook:generate-test": "npm run prebuild:storybook && npm run storybook",
    "build-storybook": "ng run valde-components:build-storybook",
    "compodoc": "compodoc -p ./tsconfig.json -n \"Valde Components\" -d ./dist/doc",
    "compodoc:dev": "compodoc -p tsconfig.json -n \"Valde Components\" -d ./dist/doc --open --serve --watch"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^17.1.0",
    "@angular/common": "^17.1.0",
    "@angular/compiler": "^17.1.0",
    "@angular/core": "^17.1.0",
    "@angular/forms": "^17.1.0",
    "@angular/platform-browser": "^17.1.0",
    "@angular/platform-browser-dynamic": "^17.1.0",
    "@angular/router": "^17.1.0",
    "@nrwl/angular": "14.4.0",
    "bootstrap": "^5.1.3",
    "bootstrap-icons": "^1.8.3",
    "rxjs": "~7.5.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
    "@angular-builders/jest": "17.0.0",
    "@angular-devkit/build-angular": "^17.1.0",
    "@angular/cli": "~17.1.0",
    "@angular/compiler-cli": "^17.1.0",
    "@babel/core": "^7.18.6",
    "@briebug/jest-schematic": "^6.0.0",
    "@compodoc/compodoc": "^1.1.19",
    "@storybook/addon-actions": "^7.6.10",
    "@storybook/addon-essentials": "^7.6.10",
    "@storybook/addon-interactions": "^7.6.10",
    "@storybook/addon-jest": "^7.6.10",
    "@storybook/addon-links": "^7.6.10",
    "@storybook/angular": "^7.6.10",
    "@storybook/testing-library": "^0.0.13",
    "@testing-library/angular": "^15.1.0",
    "@types/jest": "^29.5.11",
    "babel-loader": "^8.2.5",
    "jest": "29.7.0",
    "jest-preset-angular": "^14.0.0",
    "ng-packagr": "^17.1.0",
    "nx": "14.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "~5.3.3"
  }
}