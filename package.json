{
  "name": "valde-components",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "jest --config ./jest.app.config.js",
    "test:dev": "jest --config ./jest.app.config.js --watch-all --coverage",
    "test:my-lib": "jest --config ./jest.my-lib.config.js",
    "test:my-lib:dev": "jest --config ./jest.my-lib.config.js --watch-all --coverage",
    "test:generate-output": "jest --json --outputFile=.jest-test-results.json",
    "docs:json": "compodoc -p ./tsconfig.json -e json -d .",
    "prebuild:storybook": "npm run test:generate-output",
    "storybook": "npm run docs:json && start-storybook -p 6006",
    "storybook:generate-test": "npm run prebuild:storybook && npm run storybook",
    "build-storybook": "npm run docs:json && build-storybook",
    "compodoc": "compodoc -p ./tsconfig.json -n \"Valde Components\" -d ./dist/doc",
    "compodoc:dev": "compodoc -p tsconfig.json -n \"Valde Components\" -d ./dist/doc --open --serve --watch"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^14.0.0",
    "@angular/common": "^14.0.0",
    "@angular/compiler": "^14.0.0",
    "@angular/core": "^14.0.0",
    "@angular/forms": "^14.0.0",
    "@angular/platform-browser": "^14.0.0",
    "@angular/platform-browser-dynamic": "^14.0.0",
    "@angular/router": "^14.0.0",
    "@nrwl/angular": "14.4.0",
    "bootstrap": "^5.1.3",
    "bootstrap-icons": "^1.8.3",
    "rxjs": "~7.5.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.11.4"
  },
  "devDependencies": {
    "@angular-builders/jest": "14.0.0",
    "@angular-devkit/build-angular": "^14.0.4",
    "@angular/cli": "~14.0.4",
    "@angular/compiler-cli": "^14.0.0",
    "@babel/core": "^7.18.6",
    "@briebug/jest-schematic": "^4.0.0",
    "@compodoc/compodoc": "^1.1.19",
    "@storybook/addon-actions": "^6.5.9",
    "@storybook/addon-essentials": "^6.5.9",
    "@storybook/addon-interactions": "^6.5.9",
    "@storybook/addon-jest": "^6.5.9",
    "@storybook/addon-links": "^6.5.9",
    "@storybook/angular": "^6.5.9",
    "@storybook/builder-webpack5": "^6.5.9",
    "@storybook/manager-webpack5": "^6.5.9",
    "@storybook/testing-library": "^0.0.13",
    "@testing-library/angular": "^12.1.0",
    "@types/jest": "^29.5.11",
    "babel-loader": "^8.2.5",
    "jest": "latest",
    "jest-preset-angular": "^12.2.6",
    "ng-packagr": "^14.0.0",
    "nx": "14.4.0",
    "typescript": "~4.7.2"
  }
}
